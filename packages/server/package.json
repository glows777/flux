{
  "name": "@flux/server",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "db:push": "bunx prisma db push --schema=prisma/schema.prisma",
    "db:generate": "bunx prisma generate --schema=prisma/schema.prisma",
    "test:unit": "bun test __tests__/unit",
    "test:integration:api": "bun test --preload ./__tests__/integration/setup.ts __tests__/integration/*-api.test.ts",
    "test:integration:db": "DATABASE_URL='postgresql://flux_user:flux_password@localhost:5432/flux_test?schema=public' bun test __tests__/integration/db-models.test.ts",
    "test:integration:setup": "DATABASE_URL='postgresql://flux_user:flux_password@localhost:5432/flux_test?schema=public' bunx prisma db push --force-reset --schema=prisma/schema.prisma",
    "test:e2e": "DATABASE_URL='postgresql://flux_user:flux_password@localhost:5432/flux_test?schema=public' FINNHUB_API_KEY=test-key AI_API_KEY=test-key AI_BASE_URL=http://localhost bun test --timeout 30000 --preload ./__tests__/e2e/setup.ts __tests__/e2e",
    "test:all": "bun run test:unit && bun run test:integration:api && bun run test:integration:db && bun run test:e2e"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/xai": "^3.0.74",
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@flux/shared": "workspace:*",
    "@hono/standard-validator": "^0.2.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@tavily/core": "^0.7.2",
    "ai": "^6.0.73",
    "bash-tool": "^1.3.15",
    "croner": "^10.0.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.5",
    "hono": "^4.11.7",
    "just-bash": "^2.14.0",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "turndown": "^7.2.2",
    "undici": "^7.21.0",
    "yahoo-finance2": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/pg": "^8.16.0",
    "@types/turndown": "^5.0.6",
    "typescript": "^5"
  }
}
