# ─── Database ───
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://flux_user:flux_password@localhost:5432/flux?schema=public"

# ─── Market Data ───
ALPHA_VANTAGE_API_KEY=""

# Finnhub API key for company news (fallback data source)
# Register at: https://finnhub.io/register
FINNHUB_API_KEY=""

# FMP (Financial Modeling Prep) API key for earnings data
# Register at: https://financialmodelingprep.com/developer/docs/
# Free tier: 250 requests/day, paid: $14/month unlimited
FMP_API_KEY=""

# ─── AI: Anthropic (主力推理) ───
# Chat Agent、研报、L2 财报分析、晨报、Web Search
ANTHROPIC_API_KEY=""                     # Required: Anthropic API key
MAIN_MODEL=""                            # e.g. claude-sonnet-4-6 (Chat/研报/L2/晨报)
SEARCH_MODEL=""                          # e.g. claude-opus-4-6 (Web Search 多轮推理)
# ANTHROPIC_BASE_URL=                    # Optional: 默认 https://api.anthropic.com

# ─── AI: OpenAI-compatible (轻量任务) ───
# 搜索词生成、网页摘要等低推理需求任务
OPENAI_API_KEY=""                        # Required: OpenRouter or other OpenAI-compatible key
OPENAI_BASE_URL=""                       # Required: e.g. https://openrouter.ai/api/v1
LIGHT_MODEL=""                           # e.g. google/gemini-2.5-flash

# ─── AI: Embedding ───
# 语义嵌入 (如未设置，fallback 到 OPENAI_* 配置)
# EMBEDDING_API_KEY=                     # Falls back to OPENAI_API_KEY
# EMBEDDING_BASE_URL=                    # Falls back to OPENAI_BASE_URL
EMBEDDING_MODEL=""                       # e.g. google/gemini-embedding-001

# ─── AI: Thinking ───
# THINKING_BUDGET=10240                  # Extended thinking token budget (default: 10240)

# ─── Web Search (required for webSearch/webFetch tools) ───
TAVILY_API_KEY=tvly-...                  # Required for webSearch/webFetch tools
# JINA_API_KEY=                          # Optional: higher rate limits on page fetching

# ─── Web ───
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_ORIGINS="http://localhost:3000"

# ─── Network Proxy ───
HTTPS_PROXY=""
HTTP_PROXY=""
