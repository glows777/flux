{
    "name": "flux",
    "version": "0.1.0",
    "private": true,
    "license": "Apache-2.0",
    "workspaces": ["packages/*"],
    "scripts": {
        "dev": "bun run --filter '*' dev",
        "dev:web": "bun run --filter @flux/web dev",
        "dev:server": "bun run --filter @flux/server dev",
        "build": "bun run --filter '*' build",
        "test:all": "bun run --filter @flux/server test:all && bun run --filter @flux/web test",
        "test:server": "bun run --filter @flux/server test:all",
        "test:web": "bun run --filter @flux/web test",
        "db:push": "bun run --filter @flux/server db:push",
        "db:generate": "bun run --filter @flux/server db:generate",
        "lint": "biome check",
        "format": "biome format --write",
        "test:e2e:playwright": "bunx playwright test",
        "test:e2e:playwright:ui": "bunx playwright test --ui"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.58",
        "@ai-sdk/openai": "^3.0.25",
        "@ai-sdk/react": "^3.0.87",
        "@hono/standard-validator": "^0.2.2",
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tavily/core": "^0.7.2",
        "ai": "^6.0.73",
        "dotenv": "^17.2.3",
        "fast-xml-parser": "^5.3.5",
        "hono": "^4.11.7",
        "lucide-react": "^0.563.0",
        "next": "16.1.6",
        "pg": "^8.18.0",
        "prisma": "^7.3.0",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-markdown": "^10.1.0",
        "react-resizable-panels": "^4.6.4",
        "recharts": "^3.7.0",
        "remark-breaks": "^4.0.0",
        "swr": "^2.4.0",
        "turndown": "^7.2.2",
        "undici": "^7.21.0",
        "yahoo-finance2": "^3.13.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.0",
        "@happy-dom/global-registrator": "^20.5.0",
        "@playwright/test": "^1.58.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/bun": "^1.3.8",
        "@types/node": "^20",
        "@types/pg": "^8.16.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/turndown": "^5.0.6",
        "happy-dom": "^20.5.0",
        "msw": "^2.12.8",
        "tailwindcss": "^4",
        "typescript": "^5"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ]
}
